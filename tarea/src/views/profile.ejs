<%- include('partials/header') %>
<div class="container" style="margin-top: 30px;">
    <div class="card">
        <div class="card-content">
            <span class="card-title">Mi Perfil</span>
            <div class="row">
                <div class="col s12 m4 center-align">
                    <img id="p-avatar" src="" alt="Avatar" class="circle responsive-img" style="width:150px; height:150px; object-fit:cover; margin-bottom: 20px;">
                    <p><strong>Edad:</strong> <span id="p-age">...</span> años</p>
                    <p><strong>Roles:</strong> <span id="p-roles">...</span></p>
                    <p><strong>Email:</strong> <span id="p-email">...</span></p>
                </div>
                <div class="col s12 m8">
                    <form id="editProfileForm" enctype="multipart/form-data">
                        <div class="row">
                            <div class="input-field col s6">
                                <input id="edit-name" name="name" type="text" required>
                                <label for="edit-name" class="active">Nombre</label>
                            </div>
                            <div class="input-field col s6">
                                <input id="edit-lastName" name="lastName" type="text" required>
                                <label for="edit-lastName" class="active">Apellidos</label>
                            </div>
                        </div>
                        <div class="row">
                            <div class="input-field col s6">
                                <input id="edit-phone" name="phoneNumber" type="text" required>
                                <label for="edit-phone" class="active">Teléfono</label>
                            </div>
                            <div class="input-field col s6">
                                <input id="edit-address" name="address" type="text">
                                <label for="edit-address" class="active">Dirección</label>
                            </div>
                        </div>
                        <div class="file-field input-field">
                            <div class="btn blue">
                                <span>Cambiar Foto</span>
                                <input type="file" id="edit-avatar" name="avatar" accept="image/*">
                            </div>
                            <div class="file-path-wrapper">
                                <input class="file-path validate" type="text" placeholder="Sube una nueva foto de perfil">
                            </div>
                        </div>
                        <p id="msg-alert"></p>
                        <button type="submit" class="btn green waves-effect waves-light mt-3">Guardar Cambios</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include('partials/footer') %>
<script>
    const token = checkAuth();
    if(token) {
        
        fetch('/api/users/me', {
            headers: { 'Authorization': `Bearer ${token}` }
        })
        .then(res => {
            if(res.status === 401 || res.status === 403) logout();
            return res.json();
        })
        .then(user => {
            document.getElementById('edit-name').value = user.name;
            document.getElementById('edit-lastName').value = user.lastName || '';
            document.getElementById('edit-phone').value = user.phoneNumber || '';
            document.getElementById('edit-address').value = user.address || '';
            
            document.getElementById('p-email').innerText = user.email;
            document.getElementById('p-age').innerText = user.age || 'N/A';
            document.getElementById('p-roles').innerText = user.roles.join(', ');
            
            if(user.url_profile) {
                document.getElementById('p-avatar').src = user.url_profile;
            }
            if (typeof M !== 'undefined') M.updateTextFields();
        });

        
        document.getElementById('editProfileForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const msgAlert = document.getElementById('msg-alert');
            msgAlert.innerText = 'Guardando...';
            msgAlert.className = 'blue-text';
            
            const formData = new FormData(document.getElementById('editProfileForm'));

            try {
                const res = await fetch('/api/users/me', {
                    method: 'PUT',
                    headers: { 'Authorization': `Bearer ${token}` },
                    body: formData
                });
                
                const data = await res.json();
                if(!res.ok) throw new Error(data.message || 'Error al actualizar');
                
                msgAlert.innerText = 'Perfil actualizado exitosamente!';
                msgAlert.className = 'green-text';
                
                if(data.url_profile) {
                    document.getElementById('p-avatar').src = data.url_profile;
                }
            } catch (err) {
                msgAlert.innerText = err.message;
                msgAlert.className = 'red-text';
            }
        });
    }
</script>
